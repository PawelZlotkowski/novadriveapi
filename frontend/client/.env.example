# Vite env example — copy to `.env.local` in client/ and fill in real values.
# NEVER commit .env.local to git.

# Backend API base URL (dev: local .NET, prod: same origin via nginx proxy)
VITE_API_BASE_URL=http://localhost:5050

# Auth0 — shared tenant settings
VITE_AUTH0_DOMAIN=YOUR_TENANT.auth0.com
VITE_AUTH0_AUDIENCE=https://api.novadrive.com

# Auth0 — separate applications (SPA)
VITE_AUTH0_ADMIN_CLIENT_ID=YOUR_ADMIN_APP_CLIENT_ID
VITE_AUTH0_PASSENGER_CLIENT_ID=YOUR_PASSENGER_APP_CLIENT_ID

# Mapbox GL JS
VITE_MAPBOX_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN

